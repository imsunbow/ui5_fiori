<mvc:View controllerName="zgwe1cm0002.controller.PaymentView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizdata="sap.viz.ui5.data"
    xmlns:vizfeeds="sap.viz.ui5.controls.common.feeds">

    <Page id="page" showHeader="false" class="agingPage">
        <content>
            <VBox width="100%" class="agingShell">

                <!-- ===== Hero ===== -->
                <VBox class="agingHeroSticky">
                    <HBox class="agingHero" justifyContent="SpaceBetween" alignItems="Center" wrap="Wrap">
                        <VBox>
                            <Text text="직원 급여 관리" class="agingHeroTitle"/>
                            <Text text="사원 CRUD 및 코스트센터별 월 급여 집계·전표 생성" class="agingHeroSub"/>
                        </VBox>
                        <HBox class="agingHeroMetrics" alignItems="Center" wrap="Wrap">
                            <VBox class="agingHeroMetric">
                                <Text text="전체 사원수" class="agingHeroMetricLabel"/>
                                <Text text="{kpi>/totalEmp}명" class="agingHeroMetricValue"/>
                            </VBox>
                            <VBox class="agingHeroMetric">
                                <Text text="월 총급여" class="agingHeroMetricLabel"/>
                                <Text text="{kpi>/totalPay}억원" class="agingHeroMetricValue"/>
                            </VBox>
                            <VBox class="agingHeroMetric">
                                <Text text="급여 미처리" class="agingHeroMetricLabel"/>
                                <Text text="{kpi>/pendingCC}개" class="agingHeroMetricValue"/>
                            </VBox>
                        </HBox>
                    </HBox>
                </VBox>

                <!-- ===== KPI 카드 ===== -->
                <VBox width="100%" class="agingKpiRow">
                    <VBox class="agingKpiCard agingKpiTotal">
                        <HBox justifyContent="SpaceBetween" alignItems="Center">
                            <Text text="전체 사원수" class="agingKpiLabel"/>
                            <core:Icon src="sap-icon://employee" class="agingKpiIcon"/>
                        </HBox>
                        <Text text="{kpi>/totalEmp}" class="agingKpiValue"/>
                        <Text text="현재 등록된 전체 사원" class="agingKpiHint"/>
                    </VBox>
                    <VBox class="agingKpiCard agingKpiRisk">
                        <HBox justifyContent="SpaceBetween" alignItems="Center">
                            <Text text="월 총급여" class="agingKpiLabel"/>
                            <core:Icon src="sap-icon://money-bills" class="agingKpiIcon"/>
                        </HBox>
                        <Text text="{kpi>/totalPay}억" class="agingKpiValue"/>
                        <Text text="전체 사원 월 급여 합계" class="agingKpiHint"/>
                    </VBox>
                    <VBox class="agingKpiCard agingKpiCritical">
                        <HBox justifyContent="SpaceBetween" alignItems="Center">
                            <Text text="코스트센터 수" class="agingKpiLabel"/>
                            <core:Icon src="sap-icon://org-chart" class="agingKpiIcon"/>
                        </HBox>
                        <Text text="{kpi>/totalCC}" class="agingKpiValue"/>
                        <Text text="급여 집계 대상 코스트센터" class="agingKpiHint"/>
                    </VBox>
                    <VBox class="agingKpiCard agingKpiValueCard">
                        <HBox justifyContent="SpaceBetween" alignItems="Center">
                            <Text text="급여 미처리" class="agingKpiLabel"/>
                            <core:Icon src="sap-icon://warning" class="agingKpiIconWarn"/>
                        </HBox>
                        <Text text="{kpi>/pendingCC}" class="agingKpiValue agingKpiValueWarn"/>
                        <Text text="전표 미생성 코스트센터" class="agingKpiHint"/>
                    </VBox>
                </VBox>

                <!-- ===== 사원 관리 ===== -->
                <Panel expandable="true" expanded="true" class="agingCard">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="사원 관리" level="H2"/>
                            <ToolbarSpacer/>
                            <Button text="추가" icon="sap-icon://add"    press="onAddEmployee"/>
                            <Button text="수정" icon="sap-icon://edit"   press="onEditEmployee"/>
                            <Button text="삭제" icon="sap-icon://delete" press="onDeleteEmployee" type="Reject"/>
                            <Button text="저장" icon="sap-icon://save"   press="onSave" type="Emphasized"/>
                        </OverflowToolbar>
                    </headerToolbar>

                    <Toolbar>
                        <Label text="사원번호" class="agingFilterLabel"/>
                        <Input id="inpSearchEmpId"    width="9rem" placeholder="사원번호"   submit="onSearchEmp"/>
                        <Label text="사원명"     class="agingFilterLabel sapUiSmallMarginBegin"/>
                        <Input id="inpSearchEmpName"  width="9rem" placeholder="사원명"     submit="onSearchEmp"/>
                        <Label text="부서번호"   class="agingFilterLabel sapUiSmallMarginBegin"/>
                        <Input id="inpSearchDeptNo"   width="9rem" placeholder="부서번호"   submit="onSearchEmp"
                            showValueHelp="true" valueHelpRequest="onDeptNoValueHelp"/>
                        <Label text="코스트센터" class="agingFilterLabel sapUiSmallMarginBegin"/>
                        <Input id="inpSearchEmpKostl" width="9rem" placeholder="코스트센터" submit="onSearchEmp"
                            showValueHelp="true" valueHelpRequest="onKostlValueHelp"/>
                        <Button text="조회"   icon="sap-icon://search"      press="onSearchEmp"  type="Emphasized"/>
                        <Button text="초기화" icon="sap-icon://clear-filter" press="onClearFilter"/>
                    </Toolbar>

                    <Table id="empTable"
                        items="{local>/employees}"
                        mode="SingleSelectMaster"
                        growing="true"
                        growingThreshold="20"
                        noDataText="조회된 사원이 없습니다.">
                        <columns>
                            <Column width="8rem"><Text text="사원번호"/></Column>
                            <Column width="8rem"><Text text="사원명"/></Column>
                            <Column width="7rem"><Text text="부서번호"/></Column>
                            <Column><Text text="부서이름"/></Column>
                            <Column width="8rem"><Text text="코스트센터"/></Column>
                            <Column><Text text="코스트센터명"/></Column>
                            <Column width="5rem"><Text text="직급"/></Column>
                            <Column width="6rem"><Text text="입사연도"/></Column>
                            <Column width="10rem" hAlign="End"><Text text="급여"/></Column>
                        </columns>
                        <items>
                            <ColumnListItem vAlign="Middle">
                                <cells>
                                    <Text text="{local>EmpId}"/>
                                    <Text text="{local>EmpName}"/>
                                    <Text text="{local>DeptNo}"/>
                                    <Text text="{local>DeptName}"/>
                                    <Text text="{local>Kostl}"/>
                                    <Text text="{local>KostlName}"/>
                                    <Text text="{local>Rank}"/>
                                    <Text text="{local>EntYear}"/>
                                    <ObjectNumber number="{path: 'local>RankPay', formatter: '.formatAmount'}" unit="{local>Waers}" emphasized="false"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>

                <!-- ===== 코스트센터 집계 ===== -->
                <Panel expandable="true" expanded="true" class="agingCard">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="코스트센터별 월급 집계" level="H2"/>
                            <ToolbarSpacer/>
                            <Button text="월급 지급" icon="sap-icon://create-form" type="Emphasized" press="onCreateDocument"/>
                        </OverflowToolbar>
                    </headerToolbar>

                    <Toolbar>
                        <Label text="코스트센터" class="agingFilterLabel"/>
                        <Input id="inpSearchKostl" width="10rem" placeholder="코스트센터" submit="onSearchCC"
                            showValueHelp="true" valueHelpRequest="onKostlCCValueHelp"/>
                        <Button text="조회"   icon="sap-icon://search"      press="onSearchCC"      type="Emphasized"/>
                        <Button text="초기화" icon="sap-icon://clear-filter" press="onClearCCFilter"/>
                    </Toolbar>

                    <!-- 도넛 차트 2x2 glossy -->
                    <VBox class="ovChartArea">
                        <HBox class="ovChartRow" alignItems="Stretch">
                            <Panel headerText="1100 코스트센터 급여 분포" class="ovChartGap overviewChartPanel ovChartBlue">
                                <layoutData><FlexItemData growFactor="1" shrinkFactor="1" baseSize="0%"/></layoutData>
                                <viz:VizFrame id="chart1100" vizType="donut" height="100%" width="100%" class="ovVizFrame"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{title:{visible:false},legend:{visible:true,position:'right'},plotArea:{colorPalette:['#1a7ae8','#42a5f5','#0d47a1','#64b5f6'],background:{visible:true,gradientEnabled:true,color:'rgba(220,235,255,0.35)'}}}">
                                    <viz:dataset>
                                        <vizdata:FlattenedDataset data="{chart1100>/items}">
                                            <vizdata:dimensions>
                                                <vizdata:DimensionDefinition name="코스트센터명" value="{chart1100>SubGroup}"/>
                                            </vizdata:dimensions>
                                            <vizdata:measures>
                                                <vizdata:MeasureDefinition name="급여" value="{chart1100>RankPayNum}"/>
                                            </vizdata:measures>
                                        </vizdata:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <vizfeeds:FeedItem uid="size"  type="Measure"   values="급여"/>
                                        <vizfeeds:FeedItem uid="color" type="Dimension" values="코스트센터명"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </Panel>
                            <Panel headerText="1200 코스트센터 급여 분포" class="overviewChartPanel ovChartOrange">
                                <layoutData><FlexItemData growFactor="1" shrinkFactor="1" baseSize="0%"/></layoutData>
                                <viz:VizFrame id="chart1200" vizType="donut" height="100%" width="100%" class="ovVizFrame"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{title:{visible:false},legend:{visible:true,position:'right'},plotArea:{colorPalette:['#e8921a','#f5a742','#bf6000','#ffc76b'],background:{visible:true,gradientEnabled:true,color:'rgba(255,236,210,0.35)'}}}">
                                    <viz:dataset>
                                        <vizdata:FlattenedDataset data="{chart1200>/items}">
                                            <vizdata:dimensions>
                                                <vizdata:DimensionDefinition name="코스트센터명" value="{chart1200>SubGroup}"/>
                                            </vizdata:dimensions>
                                            <vizdata:measures>
                                                <vizdata:MeasureDefinition name="급여" value="{chart1200>RankPayNum}"/>
                                            </vizdata:measures>
                                        </vizdata:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <vizfeeds:FeedItem uid="size"  type="Measure"   values="급여"/>
                                        <vizfeeds:FeedItem uid="color" type="Dimension" values="코스트센터명"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </Panel>
                        </HBox>
                        <HBox class="ovChartRow" alignItems="Stretch">
                            <Panel headerText="1300 코스트센터 급여 분포" class="ovChartGap overviewChartPanel ovChartRed">
                                <layoutData><FlexItemData growFactor="1" shrinkFactor="1" baseSize="0%"/></layoutData>
                                <viz:VizFrame id="chart1300" vizType="donut" height="100%" width="100%" class="ovVizFrame"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{title:{visible:false},legend:{visible:true,position:'right'},plotArea:{colorPalette:['#bb0000','#e53935','#7f0000','#ef9a9a'],background:{visible:true,gradientEnabled:true,color:'rgba(255,218,218,0.35)'}}}">
                                    <viz:dataset>
                                        <vizdata:FlattenedDataset data="{chart1300>/items}">
                                            <vizdata:dimensions>
                                                <vizdata:DimensionDefinition name="코스트센터명" value="{chart1300>SubGroup}"/>
                                            </vizdata:dimensions>
                                            <vizdata:measures>
                                                <vizdata:MeasureDefinition name="급여" value="{chart1300>RankPayNum}"/>
                                            </vizdata:measures>
                                        </vizdata:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <vizfeeds:FeedItem uid="size"  type="Measure"   values="급여"/>
                                        <vizfeeds:FeedItem uid="color" type="Dimension" values="코스트센터명"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </Panel>
                            <Panel headerText="1400 코스트센터 급여 분포" class="overviewChartPanel ovChartGreen">
                                <layoutData><FlexItemData growFactor="1" shrinkFactor="1" baseSize="0%"/></layoutData>
                                <viz:VizFrame id="chart1400" vizType="donut" height="100%" width="100%" class="ovVizFrame"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{title:{visible:false},legend:{visible:true,position:'right'},plotArea:{colorPalette:['#2e7d32','#4caf50','#1b5e20','#81c784'],background:{visible:true,gradientEnabled:true,color:'rgba(210,240,218,0.35)'}}}">
                                    <viz:dataset>
                                        <vizdata:FlattenedDataset data="{chart1400>/items}">
                                            <vizdata:dimensions>
                                                <vizdata:DimensionDefinition name="코스트센터명" value="{chart1400>SubGroup}"/>
                                            </vizdata:dimensions>
                                            <vizdata:measures>
                                                <vizdata:MeasureDefinition name="급여" value="{chart1400>RankPayNum}"/>
                                            </vizdata:measures>
                                        </vizdata:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <vizfeeds:FeedItem uid="size"  type="Measure"   values="급여"/>
                                        <vizfeeds:FeedItem uid="color" type="Dimension" values="코스트센터명"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </Panel>
                        </HBox>
                    </VBox>

                    <!-- 코스트센터 테이블 -->
                    <Table id="ccTable"
                        items="{local>/ccItems}"
                        mode="MultiSelect"
                        growing="true"
                        growingThreshold="20"
                        noDataText="조회된 코스트센터가 없습니다.">
                        <columns>
                            <Column width="8rem"><Text text="코스트센터"/></Column>
                            <Column><Text text="코스트센터명"/></Column>
                            <Column width="8rem"><Text text="손익센터"/></Column>
                            <Column><Text text="손익센터명"/></Column>
                            <Column width="5rem" hAlign="End"><Text text="인원수"/></Column>
                            <Column width="10rem" hAlign="End"><Text text="총급여"/></Column>
                            <Column width="5rem"><Text text="통화"/></Column>
                            <Column width="8rem"><Text text="전표번호"/></Column>
                            <Column width="6rem" hAlign="Center"><Text text="급여상태"/></Column>
                        </columns>
                        <items>
                            <ColumnListItem vAlign="Middle">
                                <cells>
                                    <Text text="{local>Kostl}"/>
                                    <Text text="{local>KostlName}"/>
                                    <Text text="{local>Prctr}"/>
                                    <Text text="{local>PrctrName}"/>
                                    <Text text="{local>Headcount}"/>
                                    <ObjectNumber number="{path: 'local>TotalRankPayNum', formatter: '.formatAmount'}" emphasized="false"/>
                                    <Text text="{local>Waers}"/>
                                    <Text text="{local>Belnr}"/>
                                    <ObjectStatus
                                        text="{= ${local>PayStatus} === 'X' ? '완료' : '미처리'}"
                                        state="{= ${local>PayStatus} === 'X' ? 'Success' : 'Warning'}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>

            </VBox>
        </content>
    </Page>
</mvc:View>
